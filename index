<script>
/* ===== 属性術エンジン（検証済 / OFFSET は E先生確認待ち：手順準拠=51 本文準拠=50） ===== */
const ZOKUSEI=(()=>{const OFFSET=51,CYCLE=60;
  const jd=(y,m,d)=>{const a=((14-m)/12|0),yy=y+4800-a,mm=m+12*a-3;
    return d+((153*mm+2)/5|0)+365*yy+(yy/4|0)-(yy/100|0)+(yy/400|0)-32045;};
  const number=(y,m,d)=>{let n=(jd(y,m,d)+OFFSET)%CYCLE;return n===0?CYCLE:n;};
  const soul=(y,m)=>{let c=number(y,m,1)-1;return c<=0?c+CYCLE:c;};
  return{OFFSET,number,soul};})();

