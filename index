/* starfield */
(function stars(){const c=$("sky"),x=c.getContext("2d");let w,h,pts;
 function init(){w=c.width=innerWidth;h=c.height=innerHeight;
  pts=Array.from({length:Math.min(170,(w*h/8500)|0)},()=>({x:Math.random()*w,y:Math.random()*h,r:Math.random()*1.5+.2,a:Math.random()*6.28,s:Math.random()*.015+.004}));}
 function loop(){x.clearRect(0,0,w,h);for(const p of pts){p.a+=p.s;const tw=(Math.sin(p.a)+1)/2;x.globalAlpha=.13+tw*.7;x.fillStyle=tw>.85?"#f7e6b0":"#dfe6ff";x.beginPath();x.arc(p.x,p.y,p.r,0,7);x.fill();}requestAnimationFrame(loop);}
 init();loop();addEventListener("resize",init);})();
</script>
